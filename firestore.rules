rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Accounts should be deleted via administrative action or specific trigger
    }

    // Login records collection rules
    match /login_records/{recordId} {
      // Allow user to see their own login history
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      // Allow authenticated users to create a record (the backend logic will populate it)
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Disallow updates and deletions to maintain audit trail
      allow update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
